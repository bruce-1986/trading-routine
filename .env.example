# =============================================================
# BULL Trading Bot — Environment Variables Template
# NIEMALS diese Datei mit echten Keys befüllen und committen!
# Kopiere als .env (lokal) oder setze als GitHub Secrets.
# =============================================================

# --- Anthropic / Claude Code ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Alpaca Brokerage ---
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # Paper: paper-api | Live: api.alpaca.markets
ALPACA_LIVE=false                                   # Auf true setzen NUR für echtes Geld

# --- Perplexity Research ---
PERPLEXITY_API_KEY=pplx-...

# --- ClickUp Notifications ---
CLICKUP_API_KEY=pk_...
CLICKUP_LIST_ID=...         # List-ID für Trade-Tasks
CLICKUP_CRITICAL_LIST_ID=...  # Separate List für Critical Alerts

# --- Telegram (optional, Backup-Alerts) ---
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# --- GitHub (für Memory-Commits aus Actions) ---
GH_TOKEN=ghp_...            # Personal Access Token mit repo-Schreibrecht
